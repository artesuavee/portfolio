# Скопируйте в .env и заполните своими значениями.

# Ключ Anthropic Claude API (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Модель Claude (можно менять без правки кода)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Telegram-бот (для агента telegram). Токен у @BotFather
TELEGRAM_BOT_TOKEN=0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Внешние интеграции для агента automation (опционально)
CRM_WEBHOOK_URL=
TELEGRAM_NOTIFY_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
